# Database configuration
DATABASE_URL=postgres://backd:backd_password@localhost:5432/backd_platform

# Security keys (generate fresh ones for production)
BACKD_ENCRYPTION_KEY=your_32_byte_base64_encoded_encryption_key_here
BACKD_JWT_KEY=your_32_byte_base64_encoded_jwt_key_here
BACKD_SECRET_KEY=your_32_byte_base64_encoded_secret_key_here

# Storage (optional, for MinIO)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin

# API configuration
API_PORT=8080
FUNCTIONS_PORT=8081

# Development settings
LOG_LEVEL=info
ENVIRONMENT=development
