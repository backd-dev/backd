# Backd Configuration
# Copy this file to .env and update values as needed

# Required: 32-character encryption key for secrets
BACKD_ENCRYPTION_KEY=your-32-character-encryption-key-here

# Optional: Default database URL (can be overridden per app)
DATABASE_URL=postgres://backd:backd123@localhost:5432/backd_platform

# Service ports
API_PORT=8080
FUNCTIONS_PORT=8081
METRICS_PORT=9090
INTERNAL_PORT=9191

# Functions service URL (for API to call functions)
BACKD_FUNCTIONS_URL=http://localhost:8081

# Internal URL (for functions to call back into backd)
BACKD_INTERNAL_URL=http://localhost:9191

# Logging
LOG_LEVEL=info

# MinIO/S3 Configuration (for storage)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin123
STORAGE_REGION=us-east-1

# Job queue configuration
BACKD_JOB_POLL_INTERVAL=5s

# Deno pool configuration
BACKD_DENO_MIN_WORKERS=1
BACKD_DENO_MAX_WORKERS=10
BACKD_DENO_IDLE_TIMEOUT=30s

# Development settings
BACKD_FUNCTIONS_ROOT=./testdata/apps
BACKD_CONFIG_DIR=./testdata/apps
